{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Jarvis API Contract",
  "description": "Contrato de comunicación WebSocket entre Python, Java y UI",
  "definitions": {
    "PythonToJavaRequest": {
      "type": "object",
      "properties": {
        "source": { "type": "string", "enum": ["voice"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "raw_text": { "type": "string" }
      },
      "required": ["source", "timestamp", "raw_text"]
    },
    "JavaToPythonResponse": {
      "type": "object",
      "properties": {
        "intent": { "type": "string", "enum": ["OPEN_APP", "CLOSE_APP", "UNKNOWN_APP", "LEARN_ALIAS"] },
        "target": { "type": "string" },
        "tts_message": { "type": "string", "description": "Mensaje que el daemon Python deberá decir en voz alta." }
      },
      "required": ["intent"]
    },
    "JavaToUiEvent": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["HISTORY_UPDATE", "SYSTEM_STATUS"] },
        "payload": { "type": "object" }
      },
      "required": ["type", "payload"]
    }
  }
}
